{
  "name": "@ankitpandey2708/envguard",
  "version": "1.1.3",
  "description": "Validate third-party API keys at deploy time — fail fast before bad keys reach production",
  "type": "module",
  "homepage": "https://github.com/ankitpandey2708/envguard#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ankitpandey2708/envguard.git"
  },
  "bugs": {
    "url": "https://github.com/ankitpandey2708/envguard/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "envguard": "dist/cli/index.js"
  },
  "scripts": {
    "prebuild": "node scripts/gen-version.mjs",
    "build": "envguard validate && tsc",
    "dev": "tsc --watch",
    "test": "node --test dist/test/**/*.js",
    "knip": "knip",
    "postinstall": "node dist/cli/postinstall.js"
  },
  "keywords": [
    "env",
    "environment-variables",
    "environment",
    "api-key",
    "api-keys",
    "api-key-validation",
    "api-validation",
    "validation",
    "deployment",
    "preflight",
    "preflight-check",
    "fail-fast",
    "ci",
    "ci-cd",
    "github-actions",
    "continuous-deployment",
    "devops",
    "build-tools",
    "secrets",
    "security",
    "dotenv",
    "dotenv-safe",
    "openai",
    "anthropic",
    "stripe",
    "twilio",
    "gemini",
    "sarvam",
    "groq",
    "mistral",
    "openrouter",
    "togetherai",
    "cerebras",
    "nvidia",
    "posthog",
    "resend",
    "loops",
    "clerk",
    "fingerprint",
    "typescript",
    "nodejs",
    "cli",
    "vercel",
    "render",
    "fly",
    "railway"
  ],
  "files": [
    "dist"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22",
    "knip": "^6.6.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@ankitpandey2708/envguard": "^1.1.3",
    "zod": "^4.3.6"
  }
}
